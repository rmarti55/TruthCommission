# Copy to apps/web/.env.local after Block B scaffold (or use `vercel env pull`)

# Database — provision Neon via Vercel Marketplace; auto-injects POSTGRES_URL
POSTGRES_URL=

# Vercel Blob — original PDFs and ingested files
BLOB_READ_WRITE_TOKEN=

# Email — Resend (subscriber alerts, double opt-in)
RESEND_API_KEY=
EMAIL_FROM=alerts@yourdomain.com

# AI summaries — Vercel AI Gateway (recommended) or direct provider key
AI_GATEWAY_API_KEY=

# Cron / ingestion — protect /api/cron/* routes
CRON_SECRET=

# Public site URL (preview + production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
